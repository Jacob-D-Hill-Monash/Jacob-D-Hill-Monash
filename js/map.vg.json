{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 800,
  "height": 600,
  "projection": {"type": "azimuthalEqualArea","rotate": [220,90,0]},
  "title":"Antartic bases",
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/Jacob-D-Hill-Monash/FIT2179_A2/main/js/data/just_antarctic.json",
        "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
      },
      "mark": {"type": "geoshape","fill":null,"stroke": "darkgray"}
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/Jacob-D-Hill-Monash/FIT2179_A2/main/js/data/output.json",
        "format": {"type": "topojson", "feature": "claims_ps"}
      },
      "mark": {"type": "geoshape","stroke": "white","opacity": 0.2},
      "encoding": {
        "color": {
          "legend":null,
          "field": "properties.COUNTRY",
          "type": "nominal",
          "scale": {"scheme": "rainbow","reverse":false}
        },
        "tooltip": [
          {"field": "properties.COUNTRY", "type": "nominal", "title": "Country"}
        ]
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/Jacob-D-Hill-Monash/FIT2179_A2/main/js/data/Facilities_Nov2024.csv"
      },
      "mark": {"type": "circle", "opacity": 0.6, "size": 15},
      "encoding": {
        "longitude": {"field": "Longitude (DD)", "type": "quantitative"},
        "latitude": {"field": "Latitude (DD)", "type": "quantitative"},
        "color": {
          "field": "Operator (primary)",
          "type": "nominal",
          "title": "Country",
          "scale": {"type": "linear", "scheme": "turbo","reverse":false},
          "legend":{"symbolLimit": 2000}
        },
        "size": {
          "field": "Peak Population",
          "type": "quantitative",
          "title": "Population",
          "scale": {"domain": [0, 500]},
          "legend":null
        },
        "shape": {
          "field": "Type",
          "type": "nominal",
          "title": "Type"
        },
        "tooltip": [
          {"field": "Official Name", "type": "nominal", "title": "Name"},
          {"field": "Operator (primary)", "type": "nominal", "title": "Country"},
          {"field": "Year Established", "type": "quantitative", "title": "Year Established"},
          {"field": "Type", "type": "nominal", "title": "Type"},
          {"field": "Peak Population", "type": "quantitative", "title": "Population"},
          {"field": "Latitude (DD)", "type": "quantitative", "title": "Latitude"},
          {"field": "Longitude (DD)", "type": "quantitative", "title": "Longitude"}
        ]
      }
    }
  ],
  "resolve": {"scale": {"color": "independent"}},
  "config": {"title": {"font": "sans-serif", "fontSize": 14}}
}