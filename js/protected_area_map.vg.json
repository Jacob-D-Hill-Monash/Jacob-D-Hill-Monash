{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Protected Areas",
  "width": 800,
  "height": 600,
  "projection": {"type": "azimuthalEqualArea","rotate": [220,90,0]},
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/Jacob-D-Hill-Monash/FIT2179_A2/main/js/data/ASPA.json",
        "format": {"type": "topojson", "feature": "ne_110m_admin_0_countries"}
      },
      "mark": {"type": "geoshape","fill":null,"stroke": "darkgray"}
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/Jacob-D-Hill-Monash/FIT2179_A2/main/js/data/output.json",
        "format": {"type": "topojson", "feature": "claims_ps"}
      },
      "mark": {"type": "geoshape","stroke": "white","opacity": 0.2},
      "encoding": {
        "color": {
          "legend":null,
          "field": "properties.NAME",
          "type": "nominal",
          "scale": {"scheme": "rainbow","reverse":false}
        },
        "tooltip": [
          {"field": "properties.NAME", "type": "nominal", "title": "Country"}
        ]
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/Jacob-D-Hill-Monash/FIT2179_A2/main/js/data/ASPA.json",
        "format": {"type": "topojson", "feature": "ASPAs_points_v5_2024"}
      },
      "mark": {"type": "geoshape"},
      "encoding": {
        "color": {
          "field": "properties.Propon",
          "type": "nominal",
          "title": "Country",
          "scale": {"type": "linear", "scheme": "turbo","reverse":false}
        },
        "size": {
          "field": "properties.Area_km",
          "type": "quantitative",
          "title": "Area",
          "scale": {"domain": [0, 1000]}
        },
        "tooltip": [
          {"field": "properties.NAME", "type": "nominal", "title": "Name"},
          {"field": "properties.Propon", "type": "nominal", "title": "Country"},
          {"field": "properties.Area_km", "type": "quantitative", "title": "area (km^2)"}
        ]
      }
    }
  ],
  "resolve": {"scale": {"color": "independent"}},
  "config": {"title": {"font": "sans-serif", "fontSize": 14}}
}