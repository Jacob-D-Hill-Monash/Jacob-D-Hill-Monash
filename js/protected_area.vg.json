{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Protected Areas per country",
  "width": 800,
  "height": 400,
  "data": {
    "url": "https://raw.githubusercontent.com/Jacob-D-Hill-Monash/FIT2179_A2/main/js/data/ASPA.json",
    "format": {"type": "topojson", "feature": "ASPAs_points_v5_2024"}
  },
  "mark": {"type": "bar", "stroke":"black"},

  "encoding": {
    "x": {"field": "properties.Propon", "type": "nominal","title": "Country"},
    "y": { "aggregate":"count", "type": "quantitative","title":"Number of protected areas"},
    "xOffset": {"field": "properties.Name"},
    "color": {
      "field": "properties.Propon",
      "type": "nominal",
      "title": "Country",
      "scale": {"type": "linear", "scheme": "sinebow","reverse":false}
    },
    "size": {
      "field": "properties.Area_km",
      "type": "quantitative",
      "title": "Area",
      "scale": {"type": "symlog" ,"domain": [0, 400]}
    },

    "tooltip": [
      {"field": "properties.NAME", "type": "nominal", "title": "Name"},
      {"field": "properties.Propon", "type": "nominal", "title": "Country"},
      {"field": "properties.Area_km", "type": "quantitative", "title": "area (km^2)"}
    ]
  },
  "config": {"title": {"font": "sans-serif", "fontSize": 14}}
}